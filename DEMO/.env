# ─────────────────────────────────────────────────────────────────
#  KHantix AI CPQ — LLM Provider Configuration
#  Copy this file to .env and fill in the key for the provider you use.
# ─────────────────────────────────────────────────────────────────

# ── Which provider to use? ────────────────────────────────────────
# Options: "gemini" | "openai" | "anthropic" | "9router"
LLM_PROVIDER=9router

# ── 9Router (Local AI Proxy) ──────────────────────────────────────
# Default local endpoint is usually http://localhost:20128/v1
NINEROUTER_API_BASE=http://localhost:20128/v1
# Provide the default model/combo you set up in the 9Router dashboard
NINEROUTER_MODEL=ag/gemini-3.1-pro-low
# If your 9Router is secured with an Admin Key or API Key, inject it here
NINEROUTER_API_KEY=your_9router_key_here

# ── Google Gemini ─────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyB_ASOtBHqwtNKfJuIg18SR1UpzW5eriaY
GEMINI_MODEL=gemini-1.5-flash

# ── OpenAI ───────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic Claude ─────────────────────────────────────────────
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
